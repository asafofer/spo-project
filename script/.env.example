# Cloudflare R2 Configuration
R2_BUCKET_NAME=your-bucket-name

# R2 credentials (required for S3 API uploads)
# Get these from: https://dash.cloudflare.com/?to=/:account/r2/api-tokens
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key

# R2 Object Name (optional - defaults to collector.prod.js)
R2_OBJECT_NAME=collector.prod.js

# R2 Public URL (optional - for displaying the uploaded file URL)
# If your bucket has a custom domain or public URL, set it here
# Example: https://cdn.example.com or https://your-bucket.r2.dev
R2_PUBLIC_URL=

# Cloudflare Cache Purge Configuration
# Get Zone ID from: https://dash.cloudflare.com/ (select your domain, Zone ID is in the right sidebar)
CLOUDFLARE_ZONE_ID=your-zone-id

# Cloudflare API Token (required for cache purge)
# Create token at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone > Cache Purge > Purge
CLOUDFLARE_PURGE_API_TOKEN=your-api-token

#Cloudfalre's trace URL
CLOUDFLARE_TRACE_URL=your-cloudflare-domain/cdn-cgi/trace

# Axiom Endpoint URL
AXIOM_URL=your-axiom-edge/v1/ingest
# Axiom Token
AXIOM_TOKEN=your-axiom-token
# Axiom dataset for events
AXIOM_DATASET_EVENTS=prebid-events
# Axiom dataset for errors
AXIOM_DATASET_ERRORS=collector-errors

#Production's domain name
PROD_DOMAIN=trkimp.com